model Users {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  name          String   @db.VarChar(255)
  passwordHash  String   @db.VarChar(255) @map("password_hash")
  role          UserRole
  isActive      Boolean  @default(true) @db.Boolean @map("is_active")
  

  telegramId    BigInt?  @unique @map("telegram_id")

  createdAt     DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt     DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")

  // relations
  createdOrders   Orders[] @relation("CreatedOrders")
  assignedOrders  Orders[] @relation("AssignedOrders")
  auditLogs       OrderAuditLogs[]
  refreshTokens   RefreshTokens[]

  @@map("users")
}