generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  WORKER

  @@map("user_role")
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELLED
  
  @@map("order_status")
}

enum OrderPriority {
  LOW
  MEDIUM
  HIGH

  @@map("order_priority")
}
