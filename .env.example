# ===========================
# WorkTrack Backend — .env
# ===========================

# Приложение
ENVIRONMENT=development
PORT=3000

# PostgreSQL (для docker-compose)
POSTGRES_USER=worktrack
POSTGRES_PASSWORD=worktrack_secret
POSTGRES_DB=worktrack
POSTGRES_PORT=5432

# База данных (для локальной разработки без Docker)
DATABASE_URL=postgresql://worktrack:worktrack_secret@localhost:5432/worktrack

# JWT — Access Token
JWT_ACCESS_SECRET=super-secret-access-key-change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m

# JWT — Refresh Token
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Прочее
BCRYPT_ROUNDS=10
CORS_ORIGINS=http://localhost:3001,http://localhost:5173
LOG_LEVEL=info