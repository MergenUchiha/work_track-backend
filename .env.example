# ===========================
# WorkTrack Backend — .env
# ===========================

# ===========================
# ПРИЛОЖЕНИЕ
# ===========================
ENVIRONMENT=development
PORT=3000

# ===========================
# БАЗА ДАННЫХ
# ===========================

# PostgreSQL (для docker-compose)
POSTGRES_USER=worktrack
POSTGRES_PASSWORD=worktrack_secret_2026
POSTGRES_DB=worktrack
POSTGRES_PORT=5432

# URL подключения к базе данных
# Для Docker: используйте имя сервиса 'db'
# Для локальной разработки: используйте 'localhost'
DATABASE_URL=postgresql://worktrack:worktrack_secret_2026@localhost:5432/worktrack

# ===========================
# JWT АУТЕНТИФИКАЦИЯ
# ===========================

# Access Token (короткоживущий - для API запросов)
JWT_ACCESS_SECRET=super-secret-access-key-change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m

# Refresh Token (долгоживущий - для обновления сессии)
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ===========================
# БЕЗОПАСНОСТЬ
# ===========================

# Количество раундов хеширования для bcrypt (10-12 рекомендуется)
BCRYPT_ROUNDS=10

# CORS: разрешенные источники (через запятую)
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# ===========================
# ЛОГИРОВАНИЕ
# ===========================

# Уровень логирования: error | warn | info | debug | verbose
LOG_LEVEL=info

# ===========================
# TELEGRAM BOT
# ===========================

# 🤖 ВКЛЮЧИТЬ/ВЫКЛЮЧИТЬ БОТА
# true = бот работает | false = бот отключен
TELEGRAM_BOT_ENABLED=false

# Токен бота (получить у @BotFather в Telegram)
# Пример: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Режим работы бота (для продакшена)
# false = polling (опрос) | true = webhook (для HTTPS)
TELEGRAM_USE_WEBHOOK=false

# Webhook настройки (только если TELEGRAM_USE_WEBHOOK=true)
# TELEGRAM_WEBHOOK_DOMAIN=https://yourdomain.com
# TELEGRAM_WEBHOOK_PATH=/telegram-webhook

# ===========================
# ИНСТРУКЦИИ ПО НАСТРОЙКЕ
# ===========================

# 1. БАЗА ДАННЫХ:
#    - Для Docker: DATABASE_URL=postgresql://worktrack:worktrack_secret_2026@db:5432/worktrack
#    - Для локально: DATABASE_URL=postgresql://worktrack:worktrack_secret_2026@localhost:5432/worktrack

# 2. JWT СЕКРЕТЫ:
#    ⚠️ ОБЯЗАТЕЛЬНО измените в продакшене!
#    Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# 3. TELEGRAM BOT:
#    Шаг 1: Создайте бота в Telegram (@BotFather)
#    Шаг 2: Скопируйте токен
#    Шаг 3: Установите TELEGRAM_BOT_ENABLED=true
#    Шаг 4: Вставьте токен в TELEGRAM_BOT_TOKEN
#    Шаг 5: Перезапустите приложение

# 4. БЕЗ TELEGRAM БОТА:
#    Просто оставьте TELEGRAM_BOT_ENABLED=false
#    Приложение будет работать только как REST API

# ===========================
# PRODUCTION CHECKLIST
# ===========================

# ✅ Изменить JWT_ACCESS_SECRET
# ✅ Изменить JWT_REFRESH_SECRET  
# ✅ Изменить POSTGRES_PASSWORD
# ✅ Изменить DATABASE_URL с новым паролем
# ✅ Установить ENVIRONMENT=production
# ✅ Настроить CORS_ORIGINS для вашего домена
# ✅ Использовать HTTPS для webhook (если бот включен)